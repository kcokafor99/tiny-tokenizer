# Copy to backend/.env and fill in for local dev.
# NEVER commit a real .env file.

ENV=development
LOG_LEVEL=INFO

# Comma-separated list (parsed by pydantic-settings)
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Generate a strong secret in prod: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=dev-only-do-not-use-in-prod
COOKIE_NAME=tt_session
COOKIE_SECURE=false

MAX_PROMPT_CHARS=100000
RATE_LIMIT_PER_MINUTE=100

# Closed tokenizers — leave blank to disable those endpoints
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Cost guardrail
PAID_COUNT_DAILY_CAP=10000

# PostHog (server-side analytics) — leave blank to disable
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
