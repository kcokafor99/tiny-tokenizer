# Copy to frontend/.env.local for local dev.
# NEVER commit a real .env.local — secrets only live in your shell or hosting provider.

# Backend API base URL
VITE_API_BASE_URL=http://127.0.0.1:8765

# PostHog (optional — analytics disabled if blank)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
